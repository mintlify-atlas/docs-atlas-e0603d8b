{
  "projectType": "cli-tool",
  "projectName": "Gitleaks",
  "projectDescription": "Gitleaks is an open-source SAST tool for detecting hardcoded secrets like API keys, passwords, and tokens in git repositories, directories, and stdin.",
  "theme": "aspen",
  "primaryColor": "#414141",
  "lightColor": null,
  "darkColor": null,
